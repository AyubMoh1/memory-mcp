# Database location (default: ~/.memory-mcp/memory.db)
# MEMORY_DB_PATH=/path/to/memory.db

# Embedding provider (Ollama > Mock fallback)
# OLLAMA_URL=http://127.0.0.1:11434

# File watching (comma-separated paths/globs)
# MEMORY_WATCH_PATHS=/path/to/project/.claude/memory.md,/path/to/project/src/**/*.ts

# Debug logging
# DEBUG=1
